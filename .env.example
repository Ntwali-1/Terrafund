# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=postgres

# User Service Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/userdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_postgres_password

# Land Service Database
LAND_DATASOURCE_URL=jdbc:postgresql://localhost:5432/landdb
LAND_DATASOURCE_USERNAME=postgres
LAND_DATASOURCE_PASSWORD=your_postgres_password

# Investment Service Database
INVESTMENT_DATASOURCE_URL=jdbc:postgresql://localhost:5432/investmentdb
INVESTMENT_DATASOURCE_USERNAME=postgres
INVESTMENT_DATASOURCE_PASSWORD=your_postgres_password

# JWT CONFIGURATION
# Generate a secure random string for production
JWT_SECRET=your_jwt_secret_key_here

# JWT expiration time in milliseconds (86400000 = 24 hours)
JWT_EXPIRATION=86400000

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# EMAIL CONFIGURATION (if using mail service)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=YourCompany

# APPLICATION PORTS (optional overrides)
CONFIG_SERVER_PORT=8888
EUREKA_SERVER_PORT=8761
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
LAND_SERVICE_PORT=8082
INVESTMENT_SERVICE_PORT=8083
FILE_STORAGE_PORT=8084

# EUREKA CONFIGURATION
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-server:8761/eureka/

# SPRING PROFILES
SPRING_PROFILES_ACTIVE=docker
